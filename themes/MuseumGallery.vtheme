{
  "manifest": {
    "id": "museum-gallery",
    "name": "Museum Gallery",
    "version": "1.3.0",
    "builderVersion": "1.0.0",
    "minStudioVersion": "9.5.0",
    "author": "Vihu",
    "category": "Community",
    "tags": [
      "gallery",
      "art"
    ],
    "description": "A quiet gallery wall — white mat, soft light, centered.",
    "thumbnail": "data:image/png;base64,",
    "createdDate": "2026-07-06",
    "updatedDate": "2026-07-06",
    "type": "artwork",
    "displayName": "Museum Gallery",
    "purpose": "Present a child's artwork like a professional museum exhibition.",
    "mood": "Calm, refined, quietly proud.",
    "bestFor": [
      "Fine art & paintings",
      "Photography",
      "Portraits"
    ],
    "notRecommendedFor": [],
    "themeIcon": "🖼️",
    "previewImage": "data:image/png;base64,"
  },
  "theme": {
    "id": "museum-gallery",
    "name": "Museum Gallery",
    "supportedCreationTypes": [
      "artwork",
      "artwork-collection"
    ],
    "presentation": "gallery",
    "caption": "none",
    "enhancement": [],
    "layouts": [
      {
        "id": "landscape",
        "name": "Landscape",
        "aspect": "landscape",
        "description": "The classic gallery wall — a wide picture, caption below.",
        "captionPosition": "below",
        "padding": 24,
        "spacing": 16,
        "alignment": "center",
        "composition": "below"
      },
      {
        "id": "portrait",
        "name": "Portrait",
        "aspect": "portrait",
        "description": "Tall and centered, like a framed portrait.",
        "captionPosition": "below",
        "padding": 24,
        "spacing": 16,
        "alignment": "center",
        "composition": "below"
      },
      {
        "id": "quote",
        "name": "Quote",
        "aspect": "quote",
        "description": "No picture — a centered quote, beautifully set.",
        "captionPosition": "below",
        "padding": 24,
        "spacing": 16,
        "alignment": "center",
        "composition": "quote"
      }
    ],
    "frameVariations": [
      {
        "id": "classic-white",
        "name": "Classic White",
        "description": "Pure inheritance — the gallery preset's own base defaults.",
        "fields": {
          "matWidth": 24,
          "frameThickness": 2,
          "borderColor": "#ffffff",
          "wallTone": "#ffffff",
          "shadow": "soft"
        }
      },
      {
        "id": "new-frame",
        "name": "Warm Ivory",
        "description": "A soft cream mat and a warm ivory wall — cozy, not clinical.",
        "fields": {
          "matWidth": 26,
          "frameThickness": 3,
          "borderColor": "#d9c7a3",
          "wallTone": "#f2e8d5",
          "shadow": "soft"
        }
      },
      {
        "id": "new-frame-2",
        "name": "Natural Linen",
        "description": "A textured canvas paper and a muted linen wall.",
        "fields": {
          "matWidth": 24,
          "frameThickness": 2,
          "borderColor": "#c7b99b",
          "wallTone": "#e9e2d0",
          "shadow": "soft"
        }
      },
      {
        "id": "new-frame-3",
        "name": "Dark Gallery",
        "description": "A dramatic dark wall behind a bright white mat, like a night exhibition.",
        "fields": {
          "matWidth": 22,
          "frameThickness": 2,
          "borderColor": "#2a2a2a",
          "wallTone": "#1d1f24",
          "shadow": "floating"
        }
      },
      {
        "id": "new-frame-4",
        "name": "Floating Frame",
        "description": "No border line — the picture appears to float above a wide white mat.",
        "fields": {
          "matWidth": 56,
          "frameThickness": 0,
          "borderColor": "#ffffff",
          "wallTone": "#ffffff",
          "shadow": "floating"
        }
      },
      {
        "id": "new-frame-5",
        "name": "Black Matte",
        "description": "A bold black mat and border on a light wall — modern and graphic.",
        "fields": {
          "matWidth": 20,
          "frameThickness": 2,
          "borderColor": "#0a0a0a",
          "wallTone": "#d6d6d6",
          "shadow": "floating"
        }
      },
      {
        "id": "new-frame-6",
        "name": "Gold Accent",
        "description": "A warm, premium gold border on a white mat.",
        "fields": {
          "matWidth": 24,
          "frameThickness": 4,
          "borderColor": "#c9a227",
          "wallTone": "#f8f2e4",
          "shadow": "gallery"
        }
      }
    ],
    "layerPack": [
      {
        "id": "museum-caption",
        "type": "text",
        "target": "holder",
        "anchor": "bottom-center",
        "offsetX": 0,
        "offsetY": 16,
        "zIndex": 1,
        "visible": true,
        "locked": false,
        "text": {
          "source": "museumCaption"
        }
      },
      {
        "id": "page-number",
        "type": "text",
        "target": "slide",
        "anchor": "bottom-center",
        "offsetX": 0,
        "offsetY": 0,
        "zIndex": 1,
        "visible": true,
        "locked": false,
        "position": "bottom-left"
      },
      {
        "id": "handle",
        "type": "decoration",
        "target": "slide",
        "anchor": "bottom-center",
        "offsetX": 0,
        "offsetY": 0,
        "zIndex": 1,
        "visible": true,
        "locked": false,
        "position": "bottom-right"
      },
      {
        "id": "gallery-spotlight",
        "type": "decoration",
        "target": "frame",
        "anchor": "top-center",
        "offsetX": 0,
        "offsetY": 0,
        "zIndex": 0,
        "visible": true,
        "locked": false
      },
      {
        "id": "wax-seal",
        "type": "sticker",
        "target": "frame",
        "anchor": "bottom-right",
        "offsetX": -28,
        "offsetY": -28,
        "zIndex": 2,
        "visible": true,
        "locked": false
      }
    ],
    "representations": [
      {
        "id": "showcase",
        "name": "Showcase",
        "description": "Big and bold — the classic gallery look.",
        "thumbnail": "🖼️",
        "layout": "landscape",
        "defaultFrame": "classic-white",
        "defaultLayerPack": null,
        "background": null,
        "actions": [
          "editCaption"
        ]
      },
      {
        "id": "portrait",
        "name": "Portrait",
        "description": "Tall and centered, like a framed portrait.",
        "thumbnail": "🧍",
        "layout": "portrait",
        "defaultFrame": "classic-white",
        "defaultLayerPack": null,
        "background": null,
        "actions": [
          "editCaption"
        ]
      },
      {
        "id": "quote",
        "name": "Quote",
        "description": "Just your words, beautifully centered — a quote, a poem, or a certificate.",
        "thumbnail": "💬",
        "layout": "quote",
        "defaultFrame": null,
        "defaultLayerPack": null,
        "background": null,
        "actions": [
          "editQuote"
        ]
      }
    ]
  },
  "assets": {}
}